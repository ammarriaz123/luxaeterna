# ============================
# Global ingestion configuration
# ============================
# Number of webcams sampled per ingestion run
SAMPLE_SIZE=50

# Optional cap on total webcams to cache from discovery
MAX_WEBCAMS=1000

# Dataset output (directory or file path)
DATA_OUTPUT_PATH=data/processed/global_dataset

# Optional API key for webcam discovery provider (if required)
WEBCAMS_API_KEY=Qaf20SqSdJW49HDjVjAebkBDg6ttH2zC

# ============================
# Optional API keys
# ============================
# OpenWeatherMap API key for PM2.5/forecast enrichment (legacy local pipeline)
OPENWEATHERMAP_API_KEY=067bafe156dcb00fff1971c3c9b0aa0c

# ============================
# Legacy/local pipeline (optional)
# ============================
# Used only if LEGACY_LOCAL_PIPELINE=1 in run_pipeline.sh
PHOTO_LAT=40.7128
PHOTO_LON=-74.0060

# ============================
# API background ingestion
# ============================
# Interval in seconds between ingestion loops
INGEST_INTERVAL_SECONDS=10

# ============================
# Shooting coach (optional LLM)
# ============================
# Rules-based coach always runs without any key. Set COACH_LLM=1 and a key below to enrich.
#
# OpenAI: OPENAI_API_KEY + optional COACH_OPENAI_MODEL=gpt-4o-mini
# Groq: GROQ_API_KEY (or put gsk_... in OPENAI_API_KEY) — base URL auto-selected; model defaults to llama-3.3-70b-versatile
#        or set COACH_LLM_BASE_URL=https://api.groq.com/openai/v1 and COACH_OPENAI_MODEL=llama-3.1-8b-instant
# Optional override: COACH_LLM_API_KEY (wins over OPENAI_API_KEY / GROQ_API_KEY for the coach only)
COACH_LLM=0
OPENAI_API_KEY=
GROQ_API_KEY=
COACH_LLM_API_KEY=
COACH_LLM_BASE_URL=
COACH_OPENAI_MODEL=gpt-4o-mini
# openai_http (default) or langgraph
COACH_LLM_BACKEND=openai_http
